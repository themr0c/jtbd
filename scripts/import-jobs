#!/usr/bin/env python3
"""Import JTBD jobs from XLSX into Jira as tasks via jirha."""

import subprocess
import sys

import openpyxl

JOBS_SHEET = 'Phase 3 Jobs'
PROPOSAL_SHEET = 'Phase 3 JTBD - All-in Proposal'
SHEET_URL = 'https://docs.google.com/spreadsheets/d/1jVKNNUjUgHmhhTUH2wH2iX8pBlUgXaM9Je4pFlgs_9I/edit?gid=1406247735#gid=1406247735'

PRIORITY_MAP = {
    'high': 'Major',
    'medium': 'Normal',
    'low': 'Minor',
    '': 'Normal',
}

DESCRIPTION_TEMPLATE = """\
h1. Task Goal

{job_statement}

h2. Source → Target Content Map

{content_table}

h2. Instructions

Rewrite the source content listed above following JTBD principles.
Each heading should express an action + why (outcome).
Use the "Proposed JTBD Heading" column as the target heading.
Use the "Source Content" column to locate the existing content to rewrite.

h2. References

* [JTBD scoring spreadsheet|{sheet_url}]
* Category: {category}
* Job #: {job_num}
{sp_line}\
"""


def _cell(v):
    """Convert cell value to stripped string, handling None and floats."""
    if v is None:
        return ''
    if isinstance(v, float) and v == int(v):
        return str(int(v))
    return str(v).strip()


def _row_cells(row, n=5):
    """Extract first n cells from a row as stripped strings."""
    return tuple(_cell(row[i]) if i < len(row) else '' for i in range(n))


def _clean_heading(heading):
    """Strip '(Why: ...)' suffix from proposed headings."""
    return heading.split('\n')[0].strip() if heading else ''


def _entry(source, heading, sp=''):
    return {'source': source, 'heading': _clean_heading(heading), 'sp': sp}


def _flush(proposals, job, entries):
    """Store accumulated entries for a job if non-empty."""
    if job and entries:
        proposals[job] = entries


def _parse_simple_row(row):
    """Parse a simple-mode data row (cols C=source, D=heading, E=sp)."""
    source = _cell(row[2]) if len(row) > 2 else ''
    heading = _cell(row[3]) if len(row) > 3 else ''
    sp = _cell(row[4]) if len(row) > 4 else ''
    if source or heading:
        return _entry(source, heading, sp)
    return None


def _parse_detailed_row(a, b, row):
    """Parse a detailed-mode data row. Returns entry or None."""
    if a and b:
        # Layout 2: A=parent topic, B=source chapter (Secure tab)
        if b.startswith(('Chapter', '(')):
            return _entry(b, _cell(row[2]) if len(row) > 2 else '',
                          _cell(row[3]) if len(row) > 3 else '')
        # Layout 1: A=source, B=heading, C=sp
        return _entry(a, b, _cell(row[2]) if len(row) > 2 else '')
    if not a and b:
        # Continuation row (Layout 2, no parent in col A)
        return _entry(b, _cell(row[2]) if len(row) > 2 else '',
                      _cell(row[3]) if len(row) > 3 else '')
    return None


def parse_proposal(wb):
    """Parse All-in Proposal tab. Returns {job_name: [{source, heading, sp}]}."""
    if PROPOSAL_SHEET not in wb.sheetnames:
        return {}
    ws = wb[PROPOSAL_SHEET]
    rows = list(ws.iter_rows(values_only=True))

    proposals = {}
    current_job = None
    current_entries = []
    mode = None  # 'simple' or 'detailed'

    for row in rows:
        a, b, *_ = _row_cells(row)

        # Category header — flush and reset
        if a.startswith('Category:'):
            _flush(proposals, current_job, current_entries)
            current_job, current_entries, mode = None, [], None
            continue

        # Simple mode header (Discover, Plan, Install, Get Started)
        if a == 'Parent Topic (Job)' and b == 'Job Statement':
            mode = 'simple'
            continue

        # Detailed mode job header: "Job N: ..." or "Job: ..."
        if a.startswith('Job') and ':' in a and not a.startswith('Job Statement'):
            _flush(proposals, current_job, current_entries)
            current_job = a.split(':', 1)[1].strip()
            current_entries = []
            mode = 'detailed'
            continue

        # Skip header/metadata rows
        if a.startswith('Job Statement:'):
            continue
        if mode == 'detailed' and a in ('Original Source Content', 'Parent Topic', 'Mapped Content (Source)'):
            continue

        # Simple mode
        if mode == 'simple':
            if a:
                _flush(proposals, current_job, current_entries)
                current_job, current_entries = a, []
            entry = _parse_simple_row(row)
            if entry:
                current_entries.append(entry)

        # Detailed mode
        elif mode == 'detailed':
            entry = _parse_detailed_row(a, b, row)
            if entry:
                current_entries.append(entry)

    _flush(proposals, current_job, current_entries)
    return proposals


def parse_jobs(wb):
    """Parse 'Phase 3 Jobs' tab and return list of job dicts."""
    if JOBS_SHEET not in wb.sheetnames:
        print(f'ERROR: tab "{JOBS_SHEET}" not found.', file=sys.stderr)
        sys.exit(1)
    ws = wb[JOBS_SHEET]
    rows = list(ws.iter_rows(values_only=True))
    if not rows:
        return []
    headers = [str(h).strip() if h else '' for h in rows[0]]
    jobs = []
    for row in rows[1:]:
        cells = dict(zip(headers, row))
        job_num = cells.get('Job #')
        job = cells.get('Job', '')
        if not job_num or not job:
            continue
        job_num = _cell(job_num)
        job = str(job).strip()
        category = str(cells.get('Job Category ', '') or cells.get('Job Category', '') or '').strip()
        priority_raw = str(cells.get('Job Priority (calculated)', '') or '').strip().lower()
        jobs.append({
            'num': job_num,
            'name': job,
            'summary': f'JTBD - {job}',
            'statement': str(cells.get('Job Statement', '') or '').strip(),
            'category': category,
            'category_label': category.lower().replace(' ', '-'),
            'priority': PRIORITY_MAP.get(priority_raw, 'Normal'),
        })
    return jobs


def build_content_table(entries):
    """Build a Jira wiki-markup table from proposal entries."""
    if not entries:
        return '(No detailed content mapping available.)'
    lines = ['|| Source Content || Proposed JTBD Heading ||']
    for e in entries:
        lines.append(f'| {e["source"] or "—"} | {e["heading"] or "—"} |')
    return '\n'.join(lines)


def build_description(job, entries):
    sp = next((e['sp'] for e in (entries or []) if e.get('sp')), '')
    return DESCRIPTION_TEMPLATE.format(
        job_statement=job['statement'],
        content_table=build_content_table(entries),
        sheet_url=SHEET_URL,
        category=job['category'],
        job_num=job['num'],
        sp_line=f'* Estimated SP: {sp}\n' if sp else '',
    )


def print_preview(jobs, proposals):
    print(f'Found {len(jobs)} jobs to import:\n')
    matched = 0
    for job in jobs:
        n = len(proposals.get(job['name'], []))
        matched += bool(n)
        labels = f'jtbd, job-{job["num"]}, {job["category_label"]}'
        match_str = f'{n} sub-topics' if n else 'no sub-topics'
        print(f'  #{job["num"]:>2s}  [{job["priority"]:>6s}]  [{labels}]  ({match_str})')
        print(f'       {job["summary"]}')
        stmt = job['statement']
        print(f'       {stmt[:80]}...' if len(stmt) > 80 else f'       {stmt}')
        print()
    print(f'  Content mapping: {matched}/{len(jobs)} jobs matched with sub-topics from All-in Proposal\n')


def create_issue(job, entries, parent=None, dry_run=False):
    """Create a Jira task via jirha. Returns issue key or None."""
    desc = build_description(job, entries)
    if dry_run:
        labels = ', '.join(['jtbd', f'job-{job["num"]}', job['category_label']])
        parent_str = f' --parent {parent}' if parent else ''
        print(f'  [dry-run] #{job["num"]:>2s}  {job["summary"]}')
        print(f'            Type: Task  Priority: {job["priority"]}  Labels: {labels}{parent_str}')
        print('            --- Description ---')
        for line in desc.splitlines():
            print(f'            {line}')
        print()
        return None

    cmd = [
        'jirha', 'create', 'RHIDP', job['summary'],
        '--type', 'Task',
        '--priority', job['priority'],
        '--component', 'Documentation',
        '--desc', desc,
    ]
    if parent:
        cmd += ['--parent', parent]

    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        print(f'  ERROR creating #{job["num"]}: {result.stderr.strip()}', file=sys.stderr)
        return None

    for line in result.stdout.splitlines():
        if line.startswith('Created '):
            key = line.split(':')[0].replace('Created ', '').strip()
            print(f'  {key} — {job["summary"]}')
            return key
    print(f'  WARNING: unexpected output for #{job["num"]}: {result.stdout.strip()}', file=sys.stderr)
    return None


def add_labels(key, job):
    """Add labels to a created issue."""
    for label in ['jtbd', f'job-{job["num"]}', job['category_label']]:
        subprocess.run(
            ['jirha', 'update', key, '--add-label', label],
            capture_output=True, text=True)


def main():
    if len(sys.argv) < 2:
        print(f'Usage: {sys.argv[0]} <xlsx-file> [--parent EPIC-KEY] [--exec]', file=sys.stderr)
        sys.exit(1)

    xlsx_path = sys.argv[1]
    execute = '--exec' in sys.argv
    parent = None
    if '--parent' in sys.argv:
        idx = sys.argv.index('--parent')
        if idx + 1 < len(sys.argv):
            parent = sys.argv[idx + 1]
        else:
            print('ERROR: --parent requires an Epic key', file=sys.stderr)
            sys.exit(1)

    wb = openpyxl.load_workbook(xlsx_path, read_only=True, data_only=True)
    proposals = parse_proposal(wb)
    jobs = parse_jobs(wb)
    wb.close()

    if not jobs:
        print('No jobs found in XLSX.', file=sys.stderr)
        sys.exit(1)

    print_preview(jobs, proposals)

    if not execute:
        print('--- DRY RUN (pass --exec to create issues) ---\n')
        for job in jobs:
            entries = proposals.get(job['name'], [])
            create_issue(job, entries, parent=parent, dry_run=True)
        return

    if not parent:
        print('ERROR: --parent EPIC-KEY is required for creating tasks.', file=sys.stderr)
        sys.exit(1)

    print('--- Creating issues ---\n')
    created = []
    for job in jobs:
        entries = proposals.get(job['name'], [])
        key = create_issue(job, entries, parent=parent)
        if key:
            add_labels(key, job)
            created.append((job['num'], key, job['summary']))

    print(f'\n--- Summary: {len(created)}/{len(jobs)} issues created ---\n')
    for num, key, summary in created:
        print(f'  #{num:>2s}  {key:<12s}  {summary}')


if __name__ == '__main__':
    main()
